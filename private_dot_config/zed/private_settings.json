 {
  "project_panel": {
    "dock": "right"
  },
  "outline_panel": {
    "dock": "right"
  },
  "collaboration_panel": {
    "dock": "right"
  },
  "git_panel": {
    "dock": "right"
  },
  "edit_predictions": {
    "provider": "open_ai_compatible_api",
    "open_ai_compatible_api": {
      "prompt_format": "deepseek_coder",
      "model": "deepseek-reasoner",
      "api_url": "https://api.deepseek.com/v1"
    },
    "mode": "subtle",
    "copilot": {
      "proxy": null,
      "proxy_no_verify": null
    }
  },
  "show_edit_predictions": true,
  "icon_theme": "Material Icon Theme",
  "tabs": { "file_icons": true },
  "preferred_line_length": 100,
  "theme": {
    "mode": "system",
    "light": "One Light",
    "dark": "One Dark"
  },
  "buffer_font_family": "JetBrainsMono Nerd Font",
  "buffer_font_size": 14,
  "vim_mode": true,
  "terminal": {
    "font_family": "JetBrainsMono Nerd Font",
    "font_size": 13
  },
  "agent": {
    "dock": "left",
    "inline_assistant_model": {
      "provider": "deepseek",
      "model": "deepseek-chat"
    },
    "default_profile": "ask",
    "default_model": {
      "provider": "deepseek",
      "model": "deepseek-reasoner"
    }
  },
  "languages": {
    "JavaScript": {
      "formatter": [
        { "language_server": { "name": "biome" } },
        { "code_action": "source.organizeImports.biome" },
        { "code_action": "source.fixAll.biome" }
      ],
      "language_servers": ["typescript-language-server", "!eslint", "!vtsls", "..."]
    },
    "TypeScript": {
      "formatter": [
        { "language_server": { "name": "biome" } },
        { "code_action": "source.organizeImports.biome" },
        { "code_action": "source.fixAll.biome" }
      ],
      "language_servers": ["typescript-language-server", "!eslint", "!vtsls", "..."],
      "prettier": { "allowed": false }
    },
    "TSX": {
      "formatter": [
        { "language_server": { "name": "biome" } },
        { "code_action": "source.organizeImports.biome" },
        { "code_action": "source.fixAll.biome" }
      ],
      "language_servers": ["typescript-language-server", "!eslint", "!vtsls", "..."]
    },
    "JSON": {
      "formatter": [
        { "language_server": { "name": "biome" } }
      ]
    },
    "JSONC": {
      "formatter": [
        { "language_server": { "name": "biome" } }
      ]
    },
    "CSS": {
      "formatter": [
        { "language_server": { "name": "biome" } }
      ]
    },
    "Python": {
      "formatter": [
        { "language_server": { "name": "ruff" } }
      ],
      "language_servers": ["ty", "!basedpyright", "!pyright", "..."]
    },
    "Ruby": {
      "language_servers": ["ruby-lsp", "rubocop", "tailwindcss-language-server", "!solargraph", "!sorbet", "!steep", "!kanayago", "..."]
    },
    "HTML+ERB": {
      "language_servers": ["herb", "ruby-lsp", "!kanayago", "..."]
    },
    "JS+ERB": {
      "language_servers": ["ruby-lsp", "!kanayago", "..."]
    },
    "YAML+ERB": {
      "language_servers": ["ruby-lsp", "!kanayago", "..."]
    }
  },
  "lsp": {
    "biome": {
      "settings": {
        "require_config_file": true
      }
    },
    "rubocop": {
      "initialization_options": {
        "safeAutocorrect": false
      }
    },
    "ruby-lsp": {
      "initialization_options": {
        "enabledFeatures": {
          "diagnostics": false
        }
      }
    },
    "tailwindcss-language-server": {
      "settings": {
        "experimental": {
          "classRegex": ["\\bclass:\\s*['\"]([^'\"]*)['\"]"]
        }
      }
    },
    "typescript-language-server": {
      "initialization_options": {
        "preferences": {
          "includeInlayParameterNameHints": "all",
          "includeInlayParameterNameHintsWhenArgumentMatchesName": true,
          "includeInlayFunctionParameterTypeHints": true,
          "includeInlayVariableTypeHints": true,
          "includeInlayVariableTypeHintsWhenTypeMatchesName": true,
          "includeInlayPropertyDeclarationTypeHints": true,
          "includeInlayFunctionLikeReturnTypeHints": true,
          "includeInlayEnumMemberValueHints": true
        }
      }
    }
  }
}
 
